{
  "$schema": "./modules.schema.json",
  "modules": [
    {
      "name": "Claude",
      "description": "Claude Code rules, skills, and hooks",
      "setupDescription": "Claude Code settings and rules will be applied",
      "include": [".claude/settings.json", ".claude/rules/*.md"],
    },
    {
      "name": "MCP",
      "description": "MCP server configuration",
      "setupDescription": "MCP config will be applied",
      "include": [".mcp.json"],
    },
    {
      "name": "DevContainer",
      "description": "VS Code DevContainer configuration",
      "setupDescription": "DevContainer settings will be applied",
      "include": [".devcontainer/devcontainer.json", ".devcontainer/.gitignore"],
    },
    {
      "name": "GitHub",
      "description": "GitHub Actions workflows and repository settings",
      "setupDescription": "Workflow templates and repo config will be applied",
      "include": [
        ".github/workflows/issue-link.yml",
        ".github/workflows/label.yml",
        ".github/labeler.yml",
        // Excluded: ci.yml, release.yml (repo-specific CI/CD)
      ],
    },
    {
      // mise: dev tool version manager
      "name": "Tooling",
      "description": "Dev tool version management",
      "setupDescription": "Tool configs will be applied",
      "include": [".mise.toml"],
    },
  ],
}
