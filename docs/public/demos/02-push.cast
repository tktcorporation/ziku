[6.547094, "o", "\r\u001b[90m\u25c6\u001b[39m  \u001b[1mSelect files to include in PR\u001b[22m\r\n\r\n\u001b[2m\u250c\u001b[22m  .github/workflows/lint.yml \u001b[2m\u2014\u001b[22m \u001b[32madded\u001b[39m \u001b[32m+12\u001b[39m\r\n\u001b[2m\u2502\u001b[22m \u001b[36m@@ -0,0 +1,12 @@\u001b[39m\r\n\u001b[2m\u2502\u001b[22m \u001b[32m+name: Lint\u001b[39m\r\n\u001b[2m\u2502\u001b[22m \u001b[32m+on: [push, pull_request]\u001b[39m\r\n\u001b[2m\u2502\u001b[22m \u001b[32m+jobs:\u001b[39m\r\n\u001b[2m\u2502\u001b[22m \u001b[32m+  lint:\u001b[39m\r\n\u001b[2m\u2502\u001b[22m \u001b[32m+    runs-on: ubuntu-latest\u001b[39m\r\n\u001b[2m\u2502\u001b[22m \u001b[32m+    steps:\u001b[39m\r\n\u001b[2m\u2502\u001b[22m \u001b[32m+      - uses: actions/checkout@v4\u001b[39m\r\n\u001b[2m\u2502\u001b[22m \u001b[32m+      - uses: actions/setup-node@v4\u001b[39m\r\n\u001b[2m\u2502\u001b[22m \u001b[32m+        with:\u001b[39m\r\n\u001b[2m\u2502\u001b[22m \u001b[32m+          node-version: 20\u001b[39m\r\n\u001b[2m\u2502\u001b[22m \u001b[32m+      - run: npm ci\u001b[39m\r\n\u001b[2m\u2502\u001b[22m \u001b[32m+      - run: npm run lint\u001b[39m\r\n\u001b[2m\u2502\u001b[22m \r\n\u001b[2m\u2502\u001b[22m\r\n\u001b[2m\u2502\u001b[22m\r\n\u001b[2m\u2502\u001b[22m\r\n\u001b[2m\u2502\u001b[22m\r\n\u001b[2m\u2502\u001b[22m\r\n\u001b[2m\u2502\u001b[22m\r\n\u001b[2m\u2502\u001b[22m\r\n\u001b[2m\u2514\u001b[22m\r\n\r\n  \u001b[32m\u25fc\u001b[39m \u001b[33m~\u001b[39m .claude/settings.json \u001b[2m\u001b[32m+2\u001b[39m \u001b[31m-1\u001b[39m\u001b[22m\r\n  \u001b[32m\u25fc\u001b[39m \u001b[32m+\u001b[39m .devcontainer/devcontainer.env.example \u001b[2m\u001b[32m+13\u001b[39m\u001b[22m\r\n\u001b[36m\u203a\u001b[39m \u001b[32m\u25fc\u001b[39m \u001b[4m\u001b[32m+\u001b[39m .github/workflows/lint.yml\u001b[24m \u001b[2m\u001b[32m+12\u001b[39m\u001b[22m\r\n\r\n\u001b[2m  \u2191\u2193/jk navigate \u00b7 space toggle \u00b7 a all/none \u00b7 enter confirm \u00b7 Ctrl+C cancel\u001b[22m"]
