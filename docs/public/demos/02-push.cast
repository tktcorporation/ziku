[12.79463, "o", "\u001b[90m\u2502\u001b[39m\r\n\u001b[90m\u2502\u001b[39m  \u001b[2mTo\u001b[22m \u001b[1m/tmp/ziku-demo/template\u001b[22m  \u001b[2m(local)\u001b[22m\r\n\u001b[90m\u2502\u001b[39m  \u001b[2m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[22m\r\n\u001b[90m\u2502\u001b[39m    \u001b[33m~\u001b[39m .claude/settings.json                              \u001b[32m+2\u001b[39m \u001b[31m-1\u001b[39m\r\n\u001b[90m\u2502\u001b[39m    \u001b[32m+\u001b[39m .devcontainer/devcontainer.env.example             \u001b[32m+13\u001b[39m\r\n\u001b[90m\u2502\u001b[39m    \u001b[32m+\u001b[39m .github/workflows/lint.yml                         \u001b[32m+12\u001b[39m\r\n\u001b[90m\u2502\u001b[39m  \u001b[2m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[22m\r\n\u001b[90m\u2502\u001b[39m    \u001b[2mPush:\u001b[22m push 3 file(s)\r\n"]
[12.802074, "o", "\u001b[?25l\u001b[90m\u2502\u001b[39m\r\n\u001b[36m\u25c6\u001b[39m  Push to local template?\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25cf\u001b[39m Yes \u001b[2m/\u001b[22m \u001b[2m\u25cb\u001b[22m \u001b[2mNo\u001b[22m\r\n\u001b[36m\u2514\u001b[39m\r\n"]
