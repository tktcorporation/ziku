[11.295605, "o", "\u001b[2K\r\r\n\u001b[2K\r\r\n\u001b[2K\r\r\n\u001b[2K\r\u001b[30A\r\u001b[90m\u25c6\u001b[39m  \u001b[1mSelect files to include in PR\u001b[22m\r\n\r\n\u001b[2m\u250c\u001b[22m  .claude/settings.json \u001b[2m\u2014\u001b[22m \u001b[33mmodified\u001b[39m \u001b[32m+2\u001b[39m \u001b[31m-1\u001b[39m\r\n\u001b[2m\u2502\u001b[22m \u001b[36m@@ -1,8 +1,9 @@\u001b[39m\r\n\u001b[2m\u2502\u001b[22m  {\r\n\u001b[2m\u2502\u001b[22m    \"permissions\": {\r\n\u001b[2m\u2502\u001b[22m      \"allow\": [\r\n\u001b[2m\u2502\u001b[22m        \"npm test\",\r\n\u001b[2m\u2502\u001b[22m \u001b[31m-\u001b[39m      \"npm run lint\"\r\n\u001b[2m\u2502\u001b[22m \u001b[32m+\u001b[39m      \"npm run lint\"\u001b[42m\u001b[30m,\u001b[39m\u001b[49m\r\n\u001b[2m\u2502\u001b[22m \u001b[32m+      \"npm run build\"\u001b[39m\r\n\u001b[2m\u2502\u001b[22m      ]\r\n\u001b[2m\u2502\u001b[22m    }\r\n\u001b[2m\u2502\u001b[22m  }\r\n\u001b[2m\u2502\u001b[22m \r\n\u001b[2m\u2502\u001b[22m\r\n\u001b[2m\u2502\u001b[22m\r\n\u001b[2m\u2502\u001b[22m\r\n\u001b[2m\u2502\u001b[22m\r\n\u001b[2m\u2502\u001b[22m\r\n\u001b[2m\u2502\u001b[22m\r\n\u001b[2m\u2502\u001b[22m\r\n\u001b[2m\u2502\u001b[22m\r\n\u001b[2m\u2502\u001b[22m\r\n\u001b[2m\u2514\u001b[22m\r\n\r\n\u001b[36m\u203a\u001b[39m \u001b[32m\u25fc\u001b[39m \u001b[4m\u001b[33m~\u001b[39m .claude/settings.json\u001b[24m \u001b[2m\u001b[32m+2\u001b[39m \u001b[31m-1\u001b[39m\u001b[22m\r\n  \u001b[32m\u25fc\u001b[39m \u001b[32m+\u001b[39m .devcontainer/devcontainer.env.example \u001b[2m\u001b[32m+13\u001b[39m\u001b[22m\r\n  \u001b[32m\u25fc\u001b[39m \u001b[32m+\u001b[39m .github/workflows/lint.yml \u001b[2m\u001b[32m+12\u001b[39m\u001b[22m\r\n\r\n\u001b[2m  \u2191\u2193/jk navigate \u00b7 space toggle \u00b7 a all/none \u00b7 enter confirm \u00b7 Ctrl+C cancel\u001b[22m"]
