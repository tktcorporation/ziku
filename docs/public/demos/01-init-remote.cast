[16.393002, "o", "\u001b[90m│\u001b[39m\r\n\u001b[32m◇\u001b[39m  Selecting directories...\r\n"]
[16.394034, "o", "\u001b[?25l\u001b[90m│\u001b[39m\r\n\u001b[36m◆\u001b[39m  Select directories to sync\r\n\u001b[36m│\u001b[39m  \u001b[32m◼\u001b[39m .claude \u001b[2m(.claude/settings.json, .claude/hooks/*.sh, .claude/rules/*.md, .claude/skills/upstream-fix/SKILL.md, \u001b[22m\r\n\u001b[36m│\u001b[39m  \u001b[2m.claude/skills/ui-craft, .claude/skills/ui-design-research, .claude/skills/faithful-doc-writing, \u001b[22m\r\n\u001b[36m│\u001b[39m  \u001b[2m.claude/skills/autonomous-dev/SKILL.md, .claude/hookify.block-blind-kill.local.md, .claude/hookify.block-revert-others.local.md)\u001b[22m\r\n\u001b[36m│\u001b[39m  \u001b[32m◼\u001b[39m \u001b[2m.devcontainer\u001b[22m \u001b[2m(.devcontainer/devcontainer.json, .devcontainer/.gitignore, .devcontainer/setup-*.sh, .devcontainer/test-*.sh, \u001b[22m\r\n\u001b[36m│\u001b[39m  \u001b[2m.devcontainer/.env.devcontainer.example, .devcontainer/run-chrome-devtools-mcp.sh)\u001b[22m\r\n\u001b[36m│\u001b[39m  \u001b[32m◼\u001b[39m \u001b[2m.github\u001b[22m \u001b[2m(.github/workflows/issue-link.yml, .github/workflows/label.yml, .github/labeler.yml)\u001b[22m\r\n\u001b[36m│\u001b[39m  \u001b[32m◼\u001b[39m \u001b[2mRoot files\u001b[22m \u001b[2m(.mcp.json, .mise.toml)\u001b[22m\r\n\u001b[36m└\u001b[39m\r\n"]
[17.843439, "o", "\u001b[999D\u001b[10A\u001b[2B\u001b[J\u001b[36m│\u001b[39m  \u001b[32m◼\u001b[39m \u001b[2m.claude\u001b[22m \u001b[2m(.claude/settings.json, .claude/hooks/*.sh, .claude/rules/*.md, .claude/skills/upstream-fix/SKILL.md, \u001b[22m\r\n\u001b[36m│\u001b[39m  \u001b[2m.claude/skills/ui-craft, .claude/skills/ui-design-research, .claude/skills/faithful-doc-writing, \u001b[22m\r\n\u001b[36m│\u001b[39m  \u001b[2m.claude/skills/autonomous-dev/SKILL.md, .claude/hookify.block-blind-kill.local.md, .claude/hookify.block-revert-others.local.md)\u001b[22m\r\n\u001b[36m│\u001b[39m  \u001b[32m◼\u001b[39m .devcontainer \u001b[2m(.devcontainer/devcontainer.json, .devcontainer/.gitignore, .devcontainer/setup-*.sh, .devcontainer/test-*.sh, \u001b[22m\r\n\u001b[36m│\u001b[39m  \u001b[2m.devcontainer/.env.devcontainer.example, .devcontainer/run-chrome-devtools-mcp.sh)\u001b[22m\r\n\u001b[36m│\u001b[39m  \u001b[32m◼\u001b[39m \u001b[2m.github\u001b[22m \u001b[2m(.github/workflows/issue-link.yml, .github/workflows/label.yml, .github/labeler.yml)\u001b[22m\r\n\u001b[36m│\u001b[39m  \u001b[32m◼\u001b[39m \u001b[2mRoot files\u001b[22m \u001b[2m(.mcp.json, .mise.toml)\u001b[22m\r\n\u001b[36m└\u001b[39m\r\n"]
[18.214478, "o", "\u001b[999D\u001b[10A\u001b[5B\u001b[2K\u001b[G\u001b[36m│\u001b[39m  \u001b[36m◻\u001b[39m .devcontainer \u001b[2m(.devcontainer/devcontainer.json, .devcontainer/.gitignore, .devcontainer/setup-*.sh, .devcontainer/test-*.sh, \u001b[22m\u001b[5B"]
