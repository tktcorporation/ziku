[5.5, "o", "\u001b[90m\u2502\u001b[39m\r\n\u001b[90m\u2502\u001b[39m  \u001b[36m@@ -1,13 +1,14 @@\u001b[39m\r\n\u001b[90m\u2502\u001b[39m   {\r\n\u001b[90m\u2502\u001b[39m     \"name\": \"Node.js Dev\",\r\n\u001b[90m\u2502\u001b[39m     \"image\": \"mcr.microsoft.com/devcontainers/typescript-node:20\",\r\n\u001b[90m\u2502\u001b[39m  \u001b[31m-\u001b[39m  \"postCreateCommand\": \"\u001b[41m\u001b[37mnpm\u001b[39m\u001b[49m install\",\r\n\u001b[90m\u2502\u001b[39m  \u001b[32m+\u001b[39m  \"postCreateCommand\": \"\u001b[42m\u001b[30mpnpm\u001b[39m\u001b[49m install\",\r\n\u001b[90m\u2502\u001b[39m     \"customizations\": {\r\n\u001b[90m\u2502\u001b[39m       \"vscode\": {\r\n\u001b[90m\u2502\u001b[39m         \"extensions\": [\r\n\u001b[90m\u2502\u001b[39m           \"dbaeumer.vscode-eslint\",\r\n\u001b[90m\u2502\u001b[39m  \u001b[31m-\u001b[39m        \"esbenp.prettier-vscode\"\r\n\u001b[90m\u2502\u001b[39m  \u001b[32m+\u001b[39m        \"esbenp.prettier-vscode\"\u001b[42m\u001b[30m,\u001b[39m\u001b[49m\r\n\u001b[90m\u2502\u001b[39m  \u001b[32m+        \"bradlc.vscode-tailwindcss\"\u001b[39m\r\n\u001b[90m\u2502\u001b[39m         ]\r\n\u001b[90m\u2502\u001b[39m       }\r\n\u001b[90m\u2502\u001b[39m     }\r\n\u001b[90m\u2502\u001b[39m   }\r\n\u001b[90m\u2502\u001b[39m\r\n"]
