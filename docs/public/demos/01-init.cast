[3.82236, "o", "\u001b[90m\u2502\u001b[39m\r\n\u001b[36m\u25c6\u001b[39m  Select directories to sync\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25fc\u001b[39m .claude \u001b[2m(.claude/settings.json, .claude/rules/*.md, .claude/skills/**, .claude/hooks/**)\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25fc\u001b[39m \u001b[2m.devcontainer\u001b[22m \u001b[2m(.devcontainer/**)\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25fc\u001b[39m \u001b[2m.github\u001b[22m \u001b[2m(.github/**)\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25fc\u001b[39m \u001b[2mRoot files\u001b[22m \u001b[2m(.mcp.json)\u001b[22m\r\n\u001b[36m\u2514\u001b[39m\r\n"]
