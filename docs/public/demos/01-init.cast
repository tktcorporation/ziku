[25.412866, "o", "\u001b[90m\u2502\u001b[39m\r\n\u001b[90m\u2502\u001b[39m  \u001b[32m+\u001b[39m .claude/rules/code-style.md\r\n\u001b[90m\u2502\u001b[39m  \u001b[32m+\u001b[39m .claude/rules/testing.md\r\n\u001b[90m\u2502\u001b[39m  \u001b[32m+\u001b[39m .claude/settings.json\r\n\u001b[90m\u2502\u001b[39m  \u001b[32m+\u001b[39m .github/dependabot.yml\r\n\u001b[90m\u2502\u001b[39m  \u001b[32m+\u001b[39m .github/workflows/ci.yml\r\n\u001b[90m\u2502\u001b[39m  \u001b[32m+\u001b[39m .github/workflows/lint.yml\r\n\u001b[90m\u2502\u001b[39m  \u001b[32m+\u001b[39m .github/workflows/security.yml\r\n\u001b[90m\u2502\u001b[39m  \u001b[32m+\u001b[39m .ziku/ziku.jsonc\r\n\u001b[90m\u2502\u001b[39m  \u001b[32m+\u001b[39m .ziku/lock.json\r\n\u001b[90m\u2502\u001b[39m\r\n\u001b[90m\u2502\u001b[39m  \u001b[32m9 added\u001b[39m\r\n"]
[25.413141, "o", "\u001b[90m\u2502\u001b[39m\r\n\u001b[90m\u2514\u001b[39m  Setup complete!\r\n\r\n\u001b[1mNext steps:\u001b[22m\r\n  \u001b[36mgit add . && git commit -m 'chore: add ziku config'\u001b[39m\r\n  \u001b[2mCommit the changes\u001b[22m\r\n  \u001b[36mnpx ziku diff\u001b[39m\r\n  \u001b[2mCheck for updates from upstream\u001b[22m\r\n\r\n"]
