# 公開から3日未満のパッケージバージョンはインストール対象から除外する。
# 新バージョン公開直後のサプライチェーン攻撃（悪意ある publish）を緩和するため。
# ref: https://docs.pnpm.io/npmrc#min-release-age
min-release-age=3 days

# package.json の pnpm.onlyBuiltDependencies に明示されたパッケージ以外の
# インストールスクリプト（postinstall 等）を無効化する。
# 意図しないスクリプト実行によるサプライチェーン攻撃を防ぐ。
# 許可リスト: @ast-grep/cli（バイナリのビルドが必要）
ignore-scripts=true
